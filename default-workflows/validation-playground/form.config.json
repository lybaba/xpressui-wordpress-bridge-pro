    "btngroup": [
      {
        "type": "submit",
        "name": "prevbtn",
        "label": "Back",
        "adminLabel": "Back"
      },
      {
        "type": "submit",
        "name": "nextbtn",
        "label": "Continue",
        "adminLabel": "Continue"
      },
      {
        "type": "submit",
        "name": "submitbtn",
        "label": "Submit validation test",
        "adminLabel": "Submit validation test"
      }
    ]
