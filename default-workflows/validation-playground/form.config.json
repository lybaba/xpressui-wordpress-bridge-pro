      {
        "type": "file",
        "label": "Resume / CV",
        "name": "resumeFile",
        "accept": ".pdf,.doc,.docx,.odt,.rtf,.txt,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.oasis.opendocument.text,text/plain,application/rtf",
        "maxFileSizeMb": 5,
        "choices": null
      }
    ],
    "reviewStep": [
      {
        "type": "textarea",
        "label": "Additional notes",
        "name": "additionalNotes",
        "minLen": 20,
        "maxLen": 1000,
        "choices": null
      }
