        "name": "contactStep"
      },
      {
        "type": "section",
        "subType": "section",
        "label": "Step 2: Validation",
        "adminLabel": "Step 2: Validation",
        "name": "validationStep"
      },
      {
        "type": "section",
        "subType": "section",
        "label": "Step 3: Documents",
