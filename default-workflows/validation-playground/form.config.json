        "name": "documentsStep"
      },
      {
        "type": "section",
        "subType": "section",
        "label": "Step 4: Review",
        "adminLabel": "Step 4: Review",
        "name": "reviewStep"
      }
    ],
    "contactStep": [
      {
        "type": "text",
        "label": "First name",
        "name": "firstName",
        "required": true,
        "minLen": 4,
        "maxLen": 8,
        "pattern": "^[A-Za-z]{4,8}$",
        "choices": null
      },
      {
        "type": "email",
        "label": "Email",
        "name": "email",
        "required": true,
        "maxLen": 120,
        "choices": null
      },
      {
        "type": "tel",
        "label": "Phone number",
        "name": "phoneNumber",
        "required": true,
        "minLen": 7,
        "maxLen": 20,
        "choices": null
      },
      {
        "type": "radio-buttons",
        "label": "Experience level",
        "name": "experienceLevel",
        "required": true,
        "choices": [
          {
            "label": "Junior",
            "value": "junior"
          },
          {
            "label": "Senior",
            "value": "senior"
          },
          {
            "label": "Expert",
            "value": "expert"
          }
        ]
      },
      {
        "type": "radio-buttons",
        "label": "Remote only",
        "name": "remoteOnly",
        "choices": [
          {
            "label": "No",
            "value": "no"
          },
          {
            "label": "Yes",
            "value": "yes"
          }
        ]
      }
    ],
    "validationStep": [
      {
        "type": "number",
        "label": "Years of experience",
        "name": "yearsExperience",
        "min": 0,
        "max": 40,
        "choices": null
      },
      {
        "type": "price",
        "label": "Daily rate",
        "name": "dailyRate",
        "min": 50,
        "max": 5000,
        "step": 25,
        "choices": null
      },
      {
        "type": "date",
        "label": "Available from",
        "name": "availableFrom",
        "required": true,
        "choices": null
      },
      {
        "type": "time",
        "label": "Preferred call time",
        "name": "preferredCallTime",
        "required": true,
        "choices": null
      },
      {
        "type": "checkboxes",
        "label": "Available days",
        "name": "availableDays",
        "required": true,
        "minNumOfChoices": 2,
        "maxNumOfChoices": 4,
        "choices": [
          {
            "label": "Monday",
            "value": "monday"
          },
          {
            "label": "Tuesday",
            "value": "tuesday"
          },
          {
            "label": "Wednesday",
            "value": "wednesday"
          },
          {
            "label": "Thursday",
            "value": "thursday"
          },
          {
            "label": "Friday",
            "value": "friday"
          }
        ]
      },
      {
        "type": "select-multiple",
        "label": "Skills",
        "name": "skills",
        "minNumOfChoices": 1,
        "maxNumOfChoices": 3,
        "choices": [
          {
            "label": "WordPress",
            "value": "wordpress"
          },
          {
            "label": "PHP",
            "value": "php"
          },
          {
            "label": "TypeScript",
            "value": "typescript"
          },
          {
            "label": "React",
            "value": "react"
          },
          {
            "label": "Python",
            "value": "python"
          }
        ]
      },
      {
        "type": "url",
        "label": "Portfolio URL",
        "name": "portfolioUrl",
        "choices": null
      }
