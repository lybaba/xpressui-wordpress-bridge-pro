  "theme": {
    "preset_id": "console-clean",
    "layout": "centered",
    "density": "comfortable",
    "background_style": "panel",
    "colors": {
      "page_background": "#edf3fb",
      "surface": "#ffffff",
      "text": "#0f172a",
      "muted_text": "#475569",
      "primary": "#2563eb",
      "border": "#d7e0ea"
    },
    "radius": {
